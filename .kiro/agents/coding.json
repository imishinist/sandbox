{
  "name": "coding",
  "description": "General development agent for Bash sandbox scripts",
  "prompt": "file://./prompts/coding.md",
  "tools": ["read", "write", "shell"],
  "allowedTools": ["read"],
  "toolsSettings": {
    "write": {
      "allowedPaths": ["*.sh", "*.sb", "Dockerfile"]
    }
  },
  "resources": ["file://README.md", "file://DOCKER_SANDBOX.md"],
  "hooks": {
    "agentSpawn": [
      { "command": "git status --porcelain" },
      { "command": "git branch --show-current" }
    ]
  }
}
